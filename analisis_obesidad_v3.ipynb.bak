   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x400 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Las 7 clases están distribuidas de forma relativamente balanceada (272-351 casos cada una).\n"
     ]
    }
   ],
   "source": [
    "# Distribución de la variable objetivo\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "orden = df[TARGET].value_counts().index\n",
    "colores = sns.color_palette('husl', n_colors=len(orden))\n",
    "df[TARGET].value_counts().reindex(orden).plot(kind='bar', ax=ax, color=colores, edgecolor='white')\n",
    "ax.set_title('Distribución de Niveles de Obesidad')\n",
    "ax.set_xlabel('')\n",
    "ax.set_ylabel('Cantidad de Registros')\n",
    "for p in ax.patches:\n",
    "    ax.annotate(f'{int(p.get_height())}', (p.get_x() + p.get_width()/2., p.get_height()),\n",
    "                ha='center', va='bottom', fontsize=9)\n",
    "plt.xticks(rotation=30, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/01_distribucion_objetivo.png', dpi=120)\n",
    "plt.show()\n",
    "print('Las 7 clases están distribuidas de forma relativamente balanceada (272-351 casos cada una).')\n"
   ]
  },
