   "source": [
    "pipelines = {}\n",
    "print('Entrenando modelos...')\n",
    "for nombre, modelo in modelos.items():\n",
    "    pipe = Pipeline([('prep', preprocessor), ('clf', modelo)])\n",
    "    pipe.fit(X_train, y_train)\n",
    "    pipelines[nombre] = pipe\n",
    "    print(f'  ✓ {nombre}')\n",
    "print('Todos los modelos entrenados.')\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3f0726e4",
