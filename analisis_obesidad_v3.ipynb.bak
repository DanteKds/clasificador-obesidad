    "# Modelo final con k=4 (justificado por interpretabilidad del dominio) usando\n",
    "# el algoritmo seleccionado en la comparación del Paso 3.\n",
    "best_k = 4\n",
    "\n",
    "# K-Means k=4 se conserva SIEMPRE como referencia para los experimentos de la\n",
